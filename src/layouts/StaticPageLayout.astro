---
import BaseLayout from './BaseLayout.astro';
import Header from '../components/layout/Header.astro';
import Footer from '../components/layout/Footer.astro';

type Props = {
  title: string;
  description: string;
  maxWidth?: string;
};

const { title, description, maxWidth = 'max-w-3xl' } = Astro.props;
---

<BaseLayout title={title} description={description}>
  <Header />
  <main id="main-content" class={`${maxWidth} mx-auto px-6 py-12 md:py-20`}>
    <slot />
  </main>
  <Footer />
</BaseLayout>
