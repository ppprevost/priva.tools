---
import { ShieldCheck } from 'lucide-react';
import GithubIcon from '../ui/GithubIcon.astro';
import { pdfLinks, imageLinks } from '../../lib/nav-links';

const showBlog = !!process.env.DATABASE_URL;
const showSupport = !!import.meta.env.PUBLIC_PAYPAL_LINK;
---

<footer class="border-t-[3px] border-slate-900 bg-white mt-24">
  <div class="max-w-7xl mx-auto px-6 py-12">
    <div class="grid grid-cols-2 md:grid-cols-4 gap-8 mb-10">
      <div>
        <h4 class="font-black text-slate-900 mb-3">PDF Tools</h4>
        <ul class="space-y-2 text-sm text-slate-600">
          {pdfLinks.map(link => (
            <li><a href={link.href} class="hover:text-indigo-600 transition-colors">{link.label}</a></li>
          ))}
        </ul>
      </div>
      <div>
        <h4 class="font-black text-slate-900 mb-3">Image Tools</h4>
        <ul class="space-y-2 text-sm text-slate-600">
          {imageLinks.map(link => (
            <li><a href={link.href} class="hover:text-indigo-600 transition-colors">{link.label}</a></li>
          ))}
        </ul>
      </div>
      <div>
        <h4 class="font-black text-slate-900 mb-3">Company</h4>
        <ul class="space-y-2 text-sm text-slate-600">
          <li><a href="/about" class="hover:text-indigo-600 transition-colors">About</a></li>
          {showBlog && <li><a href="/blog" class="hover:text-indigo-600 transition-colors">Blog</a></li>}
          <li><a href="/privacy" class="hover:text-indigo-600 transition-colors">Privacy</a></li>
          {showSupport && <li><a href="/support" class="hover:text-indigo-600 transition-colors">Support</a></li>}
          <li><a href="/contact" class="hover:text-indigo-600 transition-colors">Contact</a></li>
          <li>
            <a href="https://github.com/ppprevost/priva.tools" target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-1.5 hover:text-indigo-600 transition-colors">
              <GithubIcon size={14} />
              GitHub
            </a>
          </li>
        </ul>
      </div>
      <div class="flex flex-col justify-end">
        <div class="flex items-center gap-2 text-sm text-slate-500 font-medium">
          <ShieldCheck size={16} className="text-emerald-500" />
          <span>Your files never leave your browser. Ever.</span>
        </div>
      </div>
    </div>
    <div class="border-t border-slate-200 pt-6 flex flex-col md:flex-row items-center justify-between gap-4">
      <div class="flex items-center gap-2">
        <div class="w-7 h-7 bg-indigo-500 rounded-lg border-2 border-slate-900 flex items-center justify-center">
          <span class="text-white font-black text-xs">P</span>
        </div>
        <span class="font-black text-slate-900">Priva.TOOLS</span>
      </div>
      <p class="text-sm text-slate-400">Free online PDF & image tools. 100% client-side processing.</p>
    </div>
  </div>
</footer>
