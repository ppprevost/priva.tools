---
import StaticPageLayout from '../layouts/StaticPageLayout.astro';
import PageHeader from '../components/ui/PageHeader.astro';
import SectionHeading from '../components/ui/SectionHeading.astro';

const sections = [
  {
    heading: 'The short version',
    content: 'Priva.TOOLS does not collect, store, or process any personal data. Your files never leave your browser. There is nothing to opt out of because we never collect anything in the first place.',
  },
  {
    heading: 'File processing',
    content: 'All file processing (compression, conversion, merging, splitting, resizing, background removal) happens entirely in your browser using WebAssembly and JavaScript. Your files are never uploaded to any server. No temporary copies are created on our infrastructure. Once you close the browser tab, any processed files in memory are released.',
  },
  {
    heading: 'Cookies',
    content: 'Priva.TOOLS does not use cookies. No session cookies, no tracking cookies, no third-party cookies. None.',
  },
  {
    heading: 'Analytics and tracking',
    content: 'Priva.TOOLS does not use Google Analytics, Facebook Pixel, or any other tracking service. We do not track page views, clicks, or user behavior. There are no analytics scripts on this website.',
  },
  {
    heading: 'Third-party services',
    content: 'Priva.TOOLS does not embed third-party scripts, ads, or social media widgets. The background removal tool downloads an AI model from a CDN on first use. This is the only external network request made by the tools. The model is cached locally by your browser for subsequent uses.',
  },
  {
    heading: 'GDPR compliance',
    content: 'Priva.TOOLS is GDPR compliant by design. Since we collect no personal data, there is no data to access, rectify, or delete. No consent banner is needed because no data processing occurs on our end.',
  },
  {
    heading: 'Contact',
    content: 'If you have questions about this privacy policy, <a href="/contact" class="text-indigo-600 font-bold hover:text-indigo-800 transition-colors">contact us</a>.',
  },
];
---

<StaticPageLayout title="Privacy Policy - Priva.TOOLS" description="Priva.TOOLS collects zero data. No cookies, no analytics, no file uploads. GDPR compliant by design." pageLabel="Privacy Policy">
  <PageHeader title="Privacy Policy" subtitle="Zero data collection. Zero cookies. GDPR compliant by design." />

  <div class="space-y-10 text-slate-600 font-medium leading-relaxed">
    {sections.map(({ heading, content }) => (
      <section>
        <SectionHeading>{heading}</SectionHeading>
        <p set:html={content} />
      </section>
    ))}
  </div>
</StaticPageLayout>
