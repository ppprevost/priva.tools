---
import ToolLayout from '../layouts/ToolLayout.astro';
import CompressImage from '../components/tools/CompressImage';
import HowToSteps from '../components/ui/HowToSteps.astro';
import FeatureGrid from '../components/ui/FeatureGrid.astro';

const faqItems = [
  { question: 'How does image compression work?', answer: 'For PNG files, we reduce the color palette (quantization). For JPG and WebP, we use lossy compression that removes visual data the human eye barely notices. Both methods significantly reduce file size.' },
  { question: 'Will my compressed image look different?', answer: 'At quality levels above 70%, the difference is usually imperceptible. Use the before/after slider to check before downloading.' },
  { question: 'Is there a file size limit?', answer: 'You can compress images up to 200 MB. Since processing happens in your browser, larger images may take a moment on slower devices.' },
  { question: 'Does the quality slider work for PNG files?', answer: 'Yes. For PNGs, the slider controls the number of colors in the output palette. Lower quality means fewer colors and a smaller file.' },
];

const howToSteps = [
  'Drop your image file (JPG, PNG, or WebP) in the box above.',
  'Adjust the quality slider to find the right balance between size and quality.',
  'The before/after preview updates in real time so you can compare.',
  "Download your compressed image when you're happy with the result.",
];

const features = [
  { title: 'PNG Compression', description: 'Uses color quantization (similar to TinyPNG) to reduce PNG file size by up to 90% while keeping transparency. The quality slider controls the number of colors in the palette.' },
  { title: 'JPG & WebP Compression', description: 'Uses lossy compression with adjustable quality. Lower quality means smaller files. The live preview lets you find the sweet spot instantly.' },
];
---

<ToolLayout
  title="Compress Image Online Free - Reduce File Size | Priva.TOOLS"
  heading="Compress Image"
  description="Compress JPG, PNG, and WebP images with adjustable quality. Real-time before/after preview. Free, no upload, 100% private."
  relatedSlugs={['resize-image', 'convert-to-jpg', 'crop-image']}
  faqItems={faqItems}
  toolSlug="compress-image"
>
  <CompressImage client:idle />

  <section class="mt-16 space-y-12 text-left" slot="seo-content">
    <HowToSteps title="How to Compress an Image" steps={howToSteps} />
    <FeatureGrid title="Smart Compression by Format" features={features} />
  </section>
</ToolLayout>
