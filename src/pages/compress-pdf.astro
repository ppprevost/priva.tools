---
import ToolLayout from '../layouts/ToolLayout.astro';
import CompressPdf from '../components/tools/CompressPdf';
import HowToSteps from '../components/ui/HowToSteps.astro';
import FeatureGrid from '../components/ui/FeatureGrid.astro';

const faqItems = [
  { question: 'Is it safe to compress my PDF online?', answer: 'Yes. Priva.TOOLS processes everything in your browser. Your file is never uploaded to any server, so there is zero risk of data leakage.' },
  { question: 'Will compression reduce the quality of my PDF?', answer: 'No. Our compression removes redundant metadata and optimizes the internal PDF structure. The visual content stays untouched.' },
  { question: 'What is the maximum file size I can compress?', answer: 'You can compress PDFs up to 200 MB. Larger files may cause your browser to slow down depending on your device.' },
  { question: 'How much smaller will my PDF be?', answer: 'Results vary depending on the PDF content. Documents with embedded images or duplicate fonts typically see 20-70% size reduction.' },
];

const howToSteps = [
  'Drop your PDF file in the box above or click "Browse" to select it.',
  'The compression starts automatically in your browser.',
  "Download your compressed PDF. That's it!",
];

const features = [
  { title: '100% Private', description: "Your PDF never leaves your device. Unlike other tools, we don't upload your files to any server. Processing happens entirely in your browser using WebAssembly." },
  { title: 'No File Size Limit', description: 'Process PDFs up to 200 MB. No artificial limits, no premium upsells, no account needed.' },
  { title: 'Preserves Quality', description: 'Our compression strips unnecessary metadata and optimizes internal structures while keeping your document visually identical.' },
  { title: 'Works Offline', description: 'Since everything runs locally, you can compress PDFs even without an internet connection after the page loads.' },
];
---

<ToolLayout
  title="Compress PDF Online Free - Reduce PDF Size | Priva.TOOLS"
  heading="Compress PDF"
  description="Reduce PDF file size without losing quality. Free, no upload, 100% browser-based compression."
  relatedSlugs={['merge-pdf', 'split-pdf', 'jpg-to-pdf']}
  faqItems={faqItems}
  toolSlug="compress-pdf"
>
  <CompressPdf client:idle />

  <section class="mt-16 space-y-12 text-left" slot="seo-content">
    <HowToSteps title="How to Compress a PDF" steps={howToSteps} />
    <FeatureGrid title="Why Compress PDFs with Priva.TOOLS?" features={features} />
  </section>
</ToolLayout>
