---
import ToolLayout from '../layouts/ToolLayout.astro';
import SplitPdf from '../components/tools/SplitPdf';
import HowToSteps from '../components/ui/HowToSteps.astro';
import FeatureGrid from '../components/ui/FeatureGrid.astro';

const faqItems = [
  { question: 'Can I extract specific pages from a PDF?', answer: 'Yes. Enter page numbers or ranges like "1-3, 5, 8-10" and each range will be saved as a separate PDF file.' },
  { question: 'What happens if I leave the page range empty?', answer: 'Every page will be extracted into its own individual PDF file.' },
];

const howToSteps = [
  'Upload your PDF file.',
  'Enter page ranges (e.g. 1-3, 5, 8-10) or leave empty to split every page.',
  'Click "Split PDF" and download the resulting files.',
];

const features = [
  { title: 'Flexible Page Ranges', description: 'Extract specific pages, page ranges, or split every page into individual files. Full control over what you extract.' },
  { title: 'Privacy First', description: 'Your PDF is processed entirely in your browser. No server upload, no cloud storage, no data retention.' },
];
---

<ToolLayout
  title="Split PDF Online Free - Extract Pages | Priva.TOOLS"
  heading="Split PDF"
  description="Extract specific pages from a PDF or split every page into separate files. Free, no upload required."
  relatedSlugs={['compress-pdf', 'merge-pdf', 'jpg-to-pdf']}
  faqItems={faqItems}
  toolSlug="split-pdf"
>
  <SplitPdf client:idle />

  <section class="mt-16 space-y-12 text-left" slot="seo-content">
    <HowToSteps title="How to Split a PDF" steps={howToSteps} />
    <FeatureGrid title="Why Split PDFs with Priva.TOOLS?" features={features} />
  </section>
</ToolLayout>
