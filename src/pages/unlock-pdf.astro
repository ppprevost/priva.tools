---
import ToolLayout from '../layouts/ToolLayout.astro';
import UnlockPdf from '../components/tools/UnlockPdf';
import HowToSteps from '../components/ui/HowToSteps.astro';
import FeatureGrid from '../components/ui/FeatureGrid.astro';

const faqItems = [
  { question: 'Is it safe to unlock my PDF here?', answer: 'Yes. Priva.TOOLS processes everything in your browser. Your file and password never leave your device, so there is zero risk of interception.' },
  { question: 'Can I unlock any PDF?', answer: 'You can unlock any PDF for which you know the password. We cannot bypass password protection on PDFs you do not own or have authorization to access.' },
  { question: 'What happens if I enter the wrong password?', answer: 'You will see a clear error message. Simply try again with the correct password. There is no attempt limit.' },
  { question: 'Will unlocking change the PDF content?', answer: 'No. Unlocking only removes the password protection. The content, layout, and formatting remain identical.' },
];

const howToSteps = [
  'Drop your PDF file in the box above or click "Browse" to select it.',
  'The tool automatically detects if your PDF is password-protected.',
  'Enter the password and click "Unlock PDF".',
  "Download your unlocked PDF. That's it!",
];

const features = [
  { title: '100% Private', description: "Your PDF and password never leave your device. Unlike other tools, we don't upload your files to any server. Decryption happens entirely in your browser using WebAssembly." },
  { title: 'Instant Detection', description: 'As soon as you drop a file, we instantly detect whether it is password-protected, so you know right away if a password is needed.' },
  { title: 'Preserves Content', description: 'Unlocking only removes the password. Your document content, layout, images, and formatting stay exactly the same.' },
  { title: 'Works Offline', description: 'Since everything runs locally, you can unlock PDFs even without an internet connection after the page loads.' },
];
---

<ToolLayout
  title="Unlock PDF Online Free - Remove PDF Password | Priva.TOOLS"
  heading="Unlock PDF"
  description="Remove the password from a protected PDF file. Free, no upload, 100% browser-based."
  relatedSlugs={['protect-pdf', 'compress-pdf', 'split-pdf']}
  faqItems={faqItems}
  toolSlug="unlock-pdf"
>
  <UnlockPdf client:idle />

  <section class="mt-16 space-y-12 text-left" slot="seo-content">
    <HowToSteps title="How to Unlock a PDF" steps={howToSteps} />
    <FeatureGrid title="Why Unlock PDFs with Priva.TOOLS?" features={features} />
  </section>
</ToolLayout>
