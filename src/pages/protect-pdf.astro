---
import ToolLayout from '../layouts/ToolLayout.astro';
import ProtectPdf from '../components/tools/ProtectPdf';
import HowToSteps from '../components/ui/HowToSteps.astro';
import FeatureGrid from '../components/ui/FeatureGrid.astro';

const faqItems = [
  { question: 'Is it safe to protect my PDF here?', answer: 'Yes. Priva.TOOLS processes everything in your browser using WebAssembly. Your file and password never leave your device.' },
  { question: 'What encryption does this use?', answer: 'We use 256-bit AES encryption, the same standard used by banks and governments. This is the strongest encryption available for PDF files.' },
  { question: 'What is the difference between user and owner password?', answer: 'The user password is required to open the PDF. The owner password controls editing permissions like printing, copying, and modifying. If you only set one password, it applies to both.' },
  { question: 'Can I restrict printing or copying?', answer: 'Yes. Use the Advanced options to set an owner password and choose which permissions to allow or deny, including printing, modifying, and text extraction.' },
];

const howToSteps = [
  'Drop your PDF file in the box above or click "Browse" to select it.',
  'Enter a password and confirm it.',
  'Optionally configure advanced permissions (printing, copying, editing).',
  'Click "Protect PDF" and download your encrypted file.',
];

const features = [
  { title: '100% Private', description: "Your PDF and password never leave your device. Unlike other tools, we don't upload your files to any server. Encryption happens entirely in your browser using WebAssembly." },
  { title: 'Military-Grade Encryption', description: '256-bit AES encryption, the strongest available for PDF. Your documents are protected with the same standard used in banking and defense.' },
  { title: 'Fine-Grained Permissions', description: 'Control exactly what recipients can do: allow or block printing, text extraction, and document modification.' },
  { title: 'Works Offline', description: 'Since everything runs locally, you can protect PDFs even without an internet connection after the page loads.' },
];
---

<ToolLayout
  title="Protect PDF with Password Online Free - AES-256 Encryption | Priva.TOOLS"
  heading="Protect PDF"
  description="Add a password to your PDF with 256-bit AES encryption. Free, no upload, 100% browser-based."
  relatedSlugs={['unlock-pdf', 'compress-pdf', 'merge-pdf']}
  faqItems={faqItems}
  toolSlug="protect-pdf"
  howToTitle="How to Protect a PDF with a Password"
  howToSteps={howToSteps}
>
  <ProtectPdf client:idle />

  <section class="mt-16 space-y-12 text-left" slot="seo-content">
    <HowToSteps title="How to Protect a PDF with a Password" steps={howToSteps} />
    <FeatureGrid title="Why Protect PDFs with Priva.TOOLS?" features={features} />
  </section>
</ToolLayout>
