---
import ToolLayout from '../layouts/ToolLayout.astro';
import EditPdf from '../components/tools/EditPdf';
import DropZoneSkeleton from '../components/ui/DropZoneSkeleton.astro';
import HowToSteps from '../components/ui/HowToSteps.astro';
import FeatureGrid from '../components/ui/FeatureGrid.astro';

const faqItems = [
  { question: 'Is my PDF uploaded to a server?', answer: 'No. All editing happens in your browser using WebAssembly. Your file never leaves your device.' },
  { question: 'What can I edit in a PDF?', answer: 'You can add text boxes, highlight text, fill in form fields, and overlay new text on top of existing content.' },
  { question: 'Does this work with encrypted PDFs?', answer: 'No. Password-protected PDFs must be unlocked first using the Unlock PDF tool.' },
  { question: 'Will the fonts look correct?', answer: 'Text boxes and overlays use Helvetica, a standard PDF font available in all PDF viewers.' },
  { question: 'Can I fill in PDF forms?', answer: 'Yes. When you open a PDF with AcroForm fields, the Form tool will detect them automatically so you can fill them in.' },
];

const howToSteps = [
  'Drop your PDF file in the box above or click "Browse" to select it.',
  'Choose a tool: Text Box, Highlight, Edit Text, or Form.',
  'Click or select on the PDF to apply your edits.',
  'Click "Save PDF" and download your edited document.',
];

const features = [
  { title: '100% Private', description: 'Your PDF is never uploaded to any server. All editing is done locally in your browser using Rust-compiled WebAssembly.' },
  { title: 'Text Box & Highlights', description: 'Add text annotations anywhere and highlight important sections with a single click or selection.' },
  { title: 'Form Filling', description: 'Automatically detects AcroForm fields in interactive PDFs so you can fill them directly in your browser.' },
  { title: 'Works Offline', description: 'After the page loads, you can edit PDFs without an internet connection.' },
];
---

<ToolLayout
  title="Edit PDF Online Free - Add Text, Highlight, Fill Forms | Priva.TOOLS"
  heading="Edit PDF"
  description="Add text boxes, highlight content, and fill in forms in any PDF. 100% private, no upload, powered by WebAssembly."
  relatedSlugs={['sign-pdf', 'protect-pdf', 'compress-pdf']}
  faqItems={faqItems}
  toolSlug="edit-pdf"
>
  <DropZoneSkeleton />
  <EditPdf client:only="react" />

  <section class="mt-16 space-y-12 text-left" slot="seo-content">
    <HowToSteps title="How to Edit a PDF Online" steps={howToSteps} />
    <FeatureGrid title="Why Edit PDFs with Priva.TOOLS?" features={features} />
  </section>
</ToolLayout>
