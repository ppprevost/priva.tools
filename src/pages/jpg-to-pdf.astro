---
import ToolLayout from '../layouts/ToolLayout.astro';
import JpgToPdf from '../components/tools/JpgToPdf';
import HowToSteps from '../components/ui/HowToSteps.astro';
import FeatureGrid from '../components/ui/FeatureGrid.astro';

const faqItems = [
  { question: 'Which image formats are supported?', answer: 'JPG, JPEG, PNG, and WebP files can be converted to PDF.' },
  { question: 'Can I combine multiple images into one PDF?', answer: 'Yes. Upload multiple images and they will all be included in a single PDF document, one image per page.' },
  { question: 'Are my images uploaded to a server?', answer: 'No. The conversion happens entirely in your browser. Your images never leave your device.' },
];

const howToSteps = [
  'Select one or more JPG, PNG, or WebP images.',
  'Click "Convert to PDF".',
  'Download your PDF with all images included.',
];

const features = [
  { title: '100% Private', description: 'Your images are converted locally in your browser. No server upload, no cloud processing, no data retention.' },
  { title: 'Multiple Images', description: 'Combine several images into a single PDF document with one image per page. Supports JPG, PNG, and WebP.' },
  { title: 'No Limits', description: 'Convert as many images as you want. No file count restrictions, no watermarks, no account required.' },
];
---

<ToolLayout
  title="JPG to PDF Converter Online Free | Priva.TOOLS"
  heading="JPG to PDF"
  description="Convert JPG, PNG, or WebP images into a PDF document. Free, fast, and 100% private."
  relatedSlugs={['compress-pdf', 'merge-pdf', 'compress-image']}
  faqItems={faqItems}
  toolSlug="jpg-to-pdf"
  howToTitle="How to Convert Images to PDF"
  howToSteps={howToSteps}
>
  <JpgToPdf client:idle />

  <section class="mt-16 space-y-12 text-left" slot="seo-content">
    <HowToSteps title="How to Convert Images to PDF" steps={howToSteps} />
    <FeatureGrid title="Why Convert Images to PDF with Priva.TOOLS?" features={features} />
  </section>
</ToolLayout>
