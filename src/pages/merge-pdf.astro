---
import ToolLayout from '../layouts/ToolLayout.astro';
import MergePdf from '../components/tools/MergePdf';
import HowToSteps from '../components/ui/HowToSteps.astro';
import FeatureGrid from '../components/ui/FeatureGrid.astro';

const faqItems = [
  { question: 'Can I merge PDFs without uploading them?', answer: 'Yes. Priva.TOOLS processes everything in your browser. Your PDFs never leave your device.' },
  { question: 'Is there a limit on how many PDFs I can merge?', answer: 'No hard limit. You can merge as many files as your browser can handle. For very large batches, processing may take a few seconds.' },
  { question: 'Will the merged PDF keep bookmarks and links?', answer: 'The merged output preserves the page content from each source file. Internal bookmarks may not be carried over depending on the PDF structure.' },
];

const howToSteps = [
  'Drop multiple PDF files or click "Browse" to select them.',
  'Reorder files by dragging if needed.',
  'Click "Merge" and download the combined PDF.',
];

const features = [
  { title: 'Complete Privacy', description: 'Your documents are merged locally in your browser. No server ever sees your files. Perfect for confidential contracts, invoices, or personal documents.' },
  { title: 'No Limits', description: 'Merge as many PDFs as you want, with no page or file count restrictions. No premium plan, no watermarks.' },
];
---

<ToolLayout
  title="Merge PDF Online Free - Combine PDF Files | Priva.TOOLS"
  heading="Merge PDF"
  description="Combine multiple PDF files into one document. Free, no upload, 100% browser-based merging."
  relatedSlugs={['compress-pdf', 'split-pdf', 'jpg-to-pdf']}
  faqItems={faqItems}
  toolSlug="merge-pdf"
  howToTitle="How to Merge PDFs"
  howToSteps={howToSteps}
>
  <MergePdf client:idle />

  <section class="mt-16 space-y-12 text-left" slot="seo-content">
    <HowToSteps title="How to Merge PDFs" steps={howToSteps} />
    <FeatureGrid title="Why Merge PDFs with Priva.TOOLS?" features={features} />
  </section>
</ToolLayout>
