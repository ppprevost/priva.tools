---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/layout/Header.astro';
import Footer from '../components/layout/Footer.astro';
import ContactForm from '../components/tools/ContactForm';
import PageHeader from '../components/ui/PageHeader.astro';

const turnstileSiteKey = import.meta.env.TURNSTILE_SITE_KEY ?? '';
---

<BaseLayout title="Contact - Priva.TOOLS" description="Get in touch with the Priva.TOOLS team. Questions, feedback, or partnership inquiries.">
  <Header />
  <main id="main-content" class="max-w-2xl mx-auto px-6 py-12 md:py-20">
    <PageHeader title="Get in touch" subtitle="Question, feedback, or just want to say hi? Drop us a message." spacing="mb-10" />
    <div class="bg-white rounded-[var(--radius-card)] border-[3px] border-slate-900 shadow-[var(--shadow-brutalist-lg)] p-6 md:p-10">
      <ContactForm client:load turnstileSiteKey={turnstileSiteKey} />
    </div>
  </main>
  <Footer />
  <script src="https://challenges.cloudflare.com/turnstile/v0/api.js" async defer></script>
</BaseLayout>
