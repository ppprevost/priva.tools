---
import ToolLayout from '../layouts/ToolLayout.astro';
import CropImage from '../components/tools/CropImage';
import HowToSteps from '../components/ui/HowToSteps.astro';
import FeatureGrid from '../components/ui/FeatureGrid.astro';

const faqItems = [
  { question: 'Can I set an exact crop size in pixels?', answer: 'The crop tool uses a visual drag-to-select interface. The crop area is calculated in exact pixels based on the original image dimensions for precise results.' },
  { question: 'Does cropping reduce image quality?', answer: 'No. Cropping simply removes the outer pixels. The remaining area keeps its original quality.' },
  { question: 'Is my image sent to a server?', answer: 'Never. All processing happens locally in your browser.' },
];

const howToSteps = [
  'Upload your image.',
  'Drag the crop handles to select the area you want to keep.',
  'Click "Crop Image" and download the cropped result.',
];

const features = [
  { title: 'Visual Precision', description: 'Drag-to-select cropping calculates exact pixel coordinates from the original image dimensions. No guesswork, no quality loss.' },
  { title: '100% Private', description: 'Your image is cropped entirely in your browser. No server upload, no cloud processing. Works offline after the page loads.' },
  { title: 'Lossless Output', description: 'Cropping removes outer pixels without re-encoding the kept area. The result preserves the original quality of your image.' },
];
---

<ToolLayout
  title="Crop Image Online Free - Precise Pixel Control | Priva.TOOLS"
  heading="Crop Image"
  description="Crop images with drag-to-select precision. Supports JPG, PNG, and WebP. Free, no upload, 100% browser-based."
  relatedSlugs={['resize-image', 'compress-image', 'remove-background']}
  faqItems={faqItems}
  toolSlug="crop-image"
  howToTitle="How to Crop an Image"
  howToSteps={howToSteps}
>
  <CropImage client:idle />

  <section class="mt-16 space-y-12 text-left" slot="seo-content">
    <HowToSteps title="How to Crop an Image" steps={howToSteps} />
    <FeatureGrid title="Why Crop Images with Priva.TOOLS?" features={features} />
  </section>
</ToolLayout>
